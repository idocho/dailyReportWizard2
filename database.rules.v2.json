{
  // ⚠️ 2차 보안 룰 초안 (#1 Firebase Auth + acl). 설계: documents/AUTH_DESIGN.md
  //    미연결·미배포 — firebase.json 에 연결 금지(1차 deny-by-default 운영 중).
  //    에뮬레이터(Java 필요)로 검증 후, 무중단 전환 절차(AUTH_DESIGN §7)로만 배포.
  //
  // 타깃 구조(단일 프로젝트):
  //   acl/{uid}              = {campus, role, instructorId, active}  ← 권한 원장(루트)
  //   schema_version         = 정수
  //   sendJobs/{campus}/...  = 관리자 일괄 전송 큐 (CampusManager 작성, 에이전트 소비)
  //   campus/{campusId}/...  = 캠퍼스별 데이터(students/classes/input/obs/scores/session/history)
  //
  // role: instructor | admin | super | agent.  active:false = 즉시 차단.
  // 표현식 주: RTDB 룰엔 함수가 없어 acl 조회를 인라인 반복한다.
  "rules": {
    ".read": false,
    ".write": false,

    "acl": {
      // 전체 명단 읽기는 admin/super 만(프라이버시)
      ".read": "auth != null && (root.child('acl').child(auth.uid).child('role').val() === 'admin' || root.child('acl').child(auth.uid).child('role').val() === 'super')",
      "$uid": {
        // 본인 엔트리는 본인도 읽기(로그인 직후 campus/role 파악)
        ".read": "auth != null && auth.uid === $uid",
        // super: 전체 / admin: 자기 캠퍼스 instructor 만(권한상승 차단)
        ".write": "auth != null && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('role').val() === 'admin' && newData.child('campus').val() === root.child('acl').child(auth.uid).child('campus').val() && newData.child('role').val() === 'instructor' && ( !data.exists() || data.child('role').val() === 'instructor' ) ) )",
        ".validate": "newData.hasChildren(['campus','role','active']) && newData.child('role').val().matches(/^(instructor|admin|super|agent)$/)"
      }
    },

    "schema_version": {
      ".read": "auth != null",
      ".write": "auth != null && root.child('acl').child(auth.uid).child('role').val() === 'super'"
    },

    "sendJobs": {
      "$campus": {
        // 읽기: 같은 캠퍼스 admin/super/agent (또는 super 전역)
        ".read": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( ( root.child('acl').child(auth.uid).child('campus').val() === $campus ) && ( root.child('acl').child(auth.uid).child('role').val() === 'admin' || root.child('acl').child(auth.uid).child('role').val() === 'agent' ) ) )",
        "$jobId": {
          // 작업 생성/수정: 같은 캠퍼스 admin/super
          ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && root.child('acl').child(auth.uid).child('role').val() === 'admin' ) )",
          "status": {
            // 상태는 같은 캠퍼스 agent 도 기록(전송 진행/결과)
            ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && root.child('acl').child(auth.uid).child('campus').val() === $campus && ( root.child('acl').child(auth.uid).child('role').val() === 'agent' || root.child('acl').child(auth.uid).child('role').val() === 'admin' || root.child('acl').child(auth.uid).child('role').val() === 'super' )"
          }
        }
      }
    },

    "campus": {
      "$campus": {
        // 캠퍼스 데이터 읽기: 같은 캠퍼스 활성 멤버(instructor/admin/agent) 또는 super
        ".read": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || root.child('acl').child(auth.uid).child('campus').val() === $campus )",

        // 명단(students/classes): 같은 캠퍼스 admin 또는 super 만 쓰기
        "students": {
          ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && root.child('acl').child(auth.uid).child('role').val() === 'admin' ) )"
        },
        "classes": {
          ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && root.child('acl').child(auth.uid).child('role').val() === 'admin' ) )"
        },

        // 수업 운영(input/obs/scores/session/history): 같은 캠퍼스 instructor/admin/super (agent 제외)
        "input":   { ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && ( root.child('acl').child(auth.uid).child('role').val() === 'instructor' || root.child('acl').child(auth.uid).child('role').val() === 'admin' ) ) )" },
        "obs":     { ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && ( root.child('acl').child(auth.uid).child('role').val() === 'instructor' || root.child('acl').child(auth.uid).child('role').val() === 'admin' ) ) )" },
        "scores":  { ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && ( root.child('acl').child(auth.uid).child('role').val() === 'instructor' || root.child('acl').child(auth.uid).child('role').val() === 'admin' ) ) )" },
        "session": { ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && ( root.child('acl').child(auth.uid).child('role').val() === 'instructor' || root.child('acl').child(auth.uid).child('role').val() === 'admin' ) ) )" },
        "history": { ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && ( root.child('acl').child(auth.uid).child('role').val() === 'instructor' || root.child('acl').child(auth.uid).child('role').val() === 'admin' ) ) )" },
        "config":  { ".write": "auth != null && root.child('acl').child(auth.uid).child('active').val() === true && ( root.child('acl').child(auth.uid).child('role').val() === 'super' || ( root.child('acl').child(auth.uid).child('campus').val() === $campus && root.child('acl').child(auth.uid).child('role').val() === 'admin' ) )" }
      }
    }
  }
}
