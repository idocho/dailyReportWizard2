{
  "database": {
    "rules": "database.rules.v2.json"
  },
  "functions": {
    "source": "functions"
  },
  "hosting": {
    "public": "code/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "redesign/**",
      "mockup-*.html",
      "v2.0.5/**",
      "v2.1.0/**",
      "v2.1.1/**",
      "v2.1.2/**",
      "v2.2.0/**",
      "v2.2.1/**",
      "v2.2.2/**",
      "v2.2.3/**",
      "v2.3.0/**",
      "v2.4.0/**"
    ],
    "redirects": [
      { "source": "/v2.0.5{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.1.0{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.1.1{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.1.2{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.2.0{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.2.1{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.2.2{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.2.3{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.3.0{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/v2.4.0{,/**}", "destination": "/v2.5.0/", "type": 302 },
      { "source": "/", "destination": "/v2.5.0/", "type": 302 }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "DENY"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=()"
          }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://www.gstatic.com; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self' https://*.firebaseio.com https://*.firebasedatabase.app https://*.googleapis.com https://*.cloudfunctions.net https://*.run.app; manifest-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
          }
        ]
      }
    ]
  }
}
