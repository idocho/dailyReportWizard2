{
  "hosting": {
    "public": "code/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "redesign/**",
      "mockup-*.html"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      },
      {
        "source": "**/*.@(html)",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  }
}
