{
  "hosting": {
    "public": "code/public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "redesign/**",
      "mockup-*.html",
      "v2.0.5/**",
      "v2.1.0/**",
      "v2.1.1/**",
      "v2.1.2/**",
      "v2.2.0/**",
      "v2.2.1/**"
    ],
    "redirects": [
      {
        "source": "/v2.0.5{,/**}",
        "destination": "/v2.3.0/",
        "type": 302
      },
      {
        "source": "/v2.1.0{,/**}",
        "destination": "/v2.3.0/",
        "type": 302
      },
      {
        "source": "/v2.1.1{,/**}",
        "destination": "/v2.3.0/",
        "type": 302
      },
      {
        "source": "/v2.1.2{,/**}",
        "destination": "/v2.3.0/",
        "type": 302
      },
      {
        "source": "/v2.2.0{,/**}",
        "destination": "/v2.3.0/",
        "type": 302
      },
      {
        "source": "/v2.2.1{,/**}",
        "destination": "/v2.3.0/",
        "type": 302
      }
    ],
    "headers": [
      {
        "source": "**/*.@(js|css)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
